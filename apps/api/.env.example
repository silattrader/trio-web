# Environment variables read by trio-api.
# Copy to .env (or set in your hosting provider) — none of these are required
# for tests to pass; they're only consulted at request time.

# --- BYOK fallback (recommended on hosted demos) ---
# When a request doesn't carry X-TRIO-* headers, the providers fall back to
# these env vars. Set them so anonymous demo-mode visitors don't get
# rate-limited by SEC / Wikimedia for missing user-agents.
TRIO_SEC_UA="Mailto you@example.com"
TRIO_WIKI_UA="Mailto you@example.com"

# Optional. Without it, FMP-backed factors (target_return + analyst_sent)
# only flow when a visitor pastes their own key in the BYOK panel. With it,
# anonymous live demo can also pull FMP — but the host eats the rate limit.
# TRIO_FMP_KEY=""

# --- PIT provider selection (server-side default) ---
# Determines which PitProvider the /backtest?strategy=rba_pit endpoint
# uses by default. Per-request keys in BYOK mode override the underlying
# provider clients but not the choice of provider.
#   mock                — synthetic deterministic (default; safe for demos)
#   edgar               — real SEC EDGAR (3 of 5 BOS factors, US-only)
#   fmp                 — analyst factors only
#   insider             — Form 4 only
#   retail              — Wikipedia only
#   edgar+fmp           — 5 of 5 PIT BOS factors
#   edgar+insider       — adds insider_flow
#   edgar+fmp+insider   — adds insider_flow + 5 BOS PIT factors
#   all                 — full 7-factor PIT (edgar + fmp + insider + retail)
# TRIO_PIT_PROVIDER=mock

# --- Cache locations (defaults are usually fine) ---
# TRIO_EDGAR_CACHE=~/.trio_cache/edgar
# TRIO_FMP_CACHE=~/.trio_cache/fmp
# TRIO_FORM4_CACHE=~/.trio_cache/form4
# TRIO_WIKI_CACHE=~/.trio_cache/wikipedia
